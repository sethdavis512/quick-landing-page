---
import { actions } from "astro:actions";
import Admin from "../layouts/Admin.astro";

const campaign = Astro.url.searchParams.get("campaign") || undefined;
const search = Astro.url.searchParams.get("search") || undefined;

const [signupsResult, campaignsResult] = await Promise.all([
  Astro.callAction(actions.getSignups, { campaign, search }),
  Astro.callAction(actions.getCampaigns, {}),
]);

const signups = signupsResult.data ?? [];
const campaigns = campaignsResult.data ?? [];
---

<Admin title="Signups">
  <h2 class="text-2xl font-bold mb-6">Signups</h2>

  <div class="flex flex-wrap gap-4 mb-6">
    <form method="GET" class="flex gap-4 flex-wrap">
      {search && <input type="hidden" name="search" value={search} />}
      <select
        name="campaign"
        onchange="this.form.submit()"
        class="border border-border rounded-md px-3 py-2 bg-surface text-text text-sm"
      >
        <option value="">All campaigns</option>
        {campaigns.map(function (c) {
          return (
            <option value={c} selected={c === campaign}>
              {c}
            </option>
          );
        })}
      </select>
    </form>

    <form method="GET" class="flex gap-2">
      {campaign && <input type="hidden" name="campaign" value={campaign} />}
      <input
        type="text"
        name="search"
        value={search ?? ""}
        placeholder="Search by email..."
        transition:persist
        class="border border-border rounded-md px-3 py-2 bg-surface text-text text-sm w-64"
      />
      <button
        type="submit"
        class="bg-accent text-white px-4 py-2 rounded-md text-sm hover:bg-accent-hover transition-colors"
      >
        Search
      </button>
    </form>

    {(campaign || search) && (
      <a
        href="/signups"
        class="px-4 py-2 text-sm text-muted hover:text-text transition-colors"
      >
        Clear filters
      </a>
    )}
  </div>

  <p class="text-sm text-muted mb-4">{signups.length} signup(s)</p>

  {signups.length === 0 ? (
    <p class="text-muted">No signups found.</p>
  ) : (
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border text-left">
            <th class="py-3 px-4 font-semibold">ID</th>
            <th class="py-3 px-4 font-semibold">Email</th>
            <th class="py-3 px-4 font-semibold">Campaign</th>
            <th class="py-3 px-4 font-semibold">Name</th>
            <th class="py-3 px-4 font-semibold">Created</th>
          </tr>
        </thead>
        <tbody>
          {signups.map(function (signup) {
            return (
              <tr class="border-b border-border hover:bg-surface/50 transition-colors">
                <td class="py-3 px-4 font-mono">{signup.id}</td>
                <td class="py-3 px-4">{signup.email}</td>
                <td class="py-3 px-4">{signup.campaign}</td>
                <td class="py-3 px-4 text-muted">{signup.name || "—"}</td>
                <td class="py-3 px-4 text-muted">{new Date(signup.created_at).toLocaleString()}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}
</Admin>
